# Docker / Compose
COMPOSE_PROJECT_NAME=keyselector-dataset
# Images build for the host architecture by default.

# Published host ports
# BACKEND_PORT is the single source of truth for the backend port. It is used
# both as the container-internal listen port (uvicorn) and as the published
# host port, and it is injected into the frontend nginx reverse proxy. Change
# it in exactly one place if port 8000 collides with another service.
BACKEND_PORT=8888
FRONTEND_PORT=3000

# Shared container paths
CONTAINER_DB_PATH=/app/db/keyselector.db
# Max size (bytes) accepted for admin ZIP uploads. Default 10 GiB.
MAX_UPLOAD_BYTES=10737418240

# OPCJONALNE: bind-mount katalogów hosta zamiast nazwanych wolumenów Dockera.
# Przydatne dla dużych zbiorów DICOM — unikasz kopiowania do kontenera.
# Struktura katalogu: jedna podfolder = jeden dataset (np. /mnt/dicom/pacjent-1/...).
# Po ustawieniu uruchom `docker compose up -d` i w panelu admina → Zbiory danych
# → "Biblioteka (niezarejestrowane)" zobaczysz podfoldery do zarejestrowania.
# HOST_LIBRARY_DIR=/absolute/path/to/dicom/library
# HOST_EXPORTS_DIR=/absolute/path/to/exports

# Backend auth settings
JWT_SECRET=replace-me-before-production
JWT_EXPIRY_HOURS=24

# Outbound sync to crai-collector (all optional; disabled by default)
# CRAI_COLLECTOR_SYNC_ENABLED=true
# CRAI_COLLECTOR_BASE_URL=http://collector.internal:8000
# CRAI_COLLECTOR_USERNAME=selector
# CRAI_COLLECTOR_PASSWORD=change-me
# CRAI_COLLECTOR_TIMEOUT_S=10
# CRAI_COLLECTOR_MAX_CONCURRENCY=4
# CRAI_COLLECTOR_ARTIFACT_REASONS=["Artefakt","Artifact","Brak kontrastu"]

# Local development helper
FRONTEND_DEV_PORT=5173