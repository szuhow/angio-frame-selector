# Docker / Compose
COMPOSE_PROJECT_NAME=keyselector-dataset
DOCKER_PLATFORM=linux/amd64

# Published host ports
BACKEND_PORT=8000
FRONTEND_PORT=3000

# Shared container paths
HOST_DATA_DIR=./backend/data
CONTAINER_DATA_DIR=/app/data
CONTAINER_DB_PATH=/app/db/keyselector.db

# Backend auth settings
JWT_SECRET=replace-me-before-production
JWT_EXPIRY_HOURS=24

# Local development helper
FRONTEND_DEV_PORT=5173